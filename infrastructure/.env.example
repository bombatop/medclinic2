# JWT signing secret — must be identical for api-gateway and auth-service (use a long random value in production).
JWT_SECRET=replace-with-strong-random-secret-min-32-chars

# When auth is served only over HTTPS, set true so refresh_token is a Secure cookie (see auth-service jwt.refresh-cookie-secure).
# JWT_REFRESH_COOKIE_SECURE=true

# PostgreSQL
POSTGRES_MAIN_USER=main_user
POSTGRES_MAIN_PASSWORD=main_pass
POSTGRES_MAIN_DB=main_service_db

POSTGRES_AUTH_USER=auth_user
POSTGRES_AUTH_PASSWORD=auth_pass
POSTGRES_AUTH_DB=auth_service_db

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Telegram (optional) — used by notification-service. Create a bot via @BotFather; admin alerts go to one chat or user id.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=

# Appointment reminder windows (optional) — main-service; comma-separated, e.g. H24,H1 or H24 only.
# MEDCLINIC_REMINDERS_POLL_INTERVAL_MS=120000
